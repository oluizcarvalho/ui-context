{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "composite": true,
    "jsx": "react-jsx",
    "types": ["node"]
  },
  "references": [
    { "path": "packages/core" },
    { "path": "packages/parser-angular" },
    { "path": "packages/parser-react" },
    { "path": "packages/mcp-server" },
    { "path": "packages/cli" }
  ],
  "files": []
}
